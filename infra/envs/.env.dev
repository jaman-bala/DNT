# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=dnt
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres_dnt
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis_dnt:6379/1

# AWS S3 / MinIO Storage
USE_AWS=False
AWS_S3_ACCESS_KEY_ID=minioadmin
AWS_S3_SECRET_ACCESS_KEY=minioadmin
AWS_S3_ENDPOINT_URL=http://minio_dnt:9000
AWS_S3_REGION_NAME=
AWS_S3_USE_SSL=False
AWS_S3_VERIFY=False
AWS_S3_URL_PROTOCOL=http://
AWS_STORAGE_BUCKET_NAME=media
AWS_STORAGE_STATIC_BUCKET_NAME=static
S3_URL_EXPIRATION_TIME=3600
AWS_S3_DEFAULT_ACL=public-read
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_MEDIA_QUERYSTRING_AUTH=True
AWS_S3_STATIC_ACL=public-read
AWS_S3_STATIC_QUERYSTRING_AUTH=False
MINIO_BASE_DOMAIN=minio_dnt:9000
MINIO_S3_CUSTOM_DOMAIN=
ENABLE_STORAGE_CUSTOM_DOMAIN=False

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-here

# MinIO
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Redis
REDIS_URL=redis://redis_dnt:6379/0
